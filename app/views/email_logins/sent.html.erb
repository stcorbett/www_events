<div class="row">
  <div class="col-md-6 col-sm-6">
    <div class="well">
      <h4>Check your email</h4>
      <p>Click the link in your email to log in.</p>
      <p>Definitely check your SPAM folder</p>
      <p class="text-muted small">
        The link is good for one hour. If you don't see the email in a minute or two,
        check your spam folder — or
        <%= link_to "try again", email_login_path %>.
      </p>
    </div>
  </div>
</div>
