<%= render 'admin/flash_messages' %>

<div class="row">
  <div class="col-md-12">
    <h3>Merge Complete: <%= resource_label %></h3>
    <p class="text-muted">
      Events have been moved from <strong><%= display_label(@source) %></strong>
      to <strong><%= display_label(@target) %></strong>.
      The <%= resource_label.downcase %> "<%= @source.name %>" still exists but is empty.
      Choose one of the actions on the left to finish cleaning up — or leave it as-is.
    </p>
  </div>
</div>

<div class="row">
  <div class="col-md-6">
    <div class="card mb-3 border-warning">
      <div class="card-header bg-warning-subtle">
        <h5 class="mb-0">Source <small class="text-muted">(empty after merge)</small></h5>
      </div>
      <div class="card-body">
        <h6>
          <%= @source.name %>
          <small class="text-muted">id=<%= @source.id %></small>
          <% if @source.archived %><span class="badge bg-secondary">Archived</span><% end %>
        </h6>

        <div class="my-3">
          <%= button_to "Archive #{resource_label}",
                        merge_archive_url,
                        method: :patch,
                        class: "btn btn-warning",
                        form: { style: "display:inline" } %>
          <%= button_to "Delete #{resource_label}",
                        merge_delete_url,
                        method: :delete,
                        class: "btn btn-danger ms-2",
                        form: { style: "display:inline" },
                        data: { confirm: "Permanently delete #{display_label(@source)}? This can't be undone." } %>
        </div>
        <p class="form-text text-muted">
          Archive → keeps the record but hides it from participant-facing autocompletes; redirects to the source's show page.<br>
          Delete → permanently removes the record; redirects to the target's show page.
        </p>

        <h6 class="mt-3">Current Events (<%= @source_current_events.size %>)</h6>
        <%= render 'admin/events_table',
                   events:        @source_current_events,
                   empty_message: "No current events.",
                   show_actions:  false,
                   card_wrap:     false %>

        <h6 class="mt-3">Past Events (<%= @source_past_events.size %>)</h6>
        <%= render 'admin/events_table',
                   events:        @source_past_events,
                   empty_message: "No past events.",
                   show_actions:  false,
                   card_wrap:     false,
                   show_year:     true %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card mb-3 border-success">
      <div class="card-header bg-success-subtle">
        <h5 class="mb-0">Target <small class="text-muted">(received all events)</small></h5>
      </div>
      <div class="card-body">
        <h6>
          <%= @target.name %>
          <small class="text-muted">id=<%= @target.id %></small>
        </h6>

        <h6 class="mt-3">Current Events (<%= @target_current_events.size %>)</h6>
        <%= render 'admin/events_table',
                   events:        @target_current_events,
                   empty_message: "No current events.",
                   show_actions:  false,
                   card_wrap:     false %>

        <h6 class="mt-3">Past Events (<%= @target_past_events.size %>)</h6>
        <%= render 'admin/events_table',
                   events:        @target_past_events,
                   empty_message: "No past events.",
                   show_actions:  false,
                   card_wrap:     false,
                   show_year:     true %>
      </div>
    </div>
  </div>
</div>
