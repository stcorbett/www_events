<div class="row">
  <div class="col-md-12">
    <h3><%= @location.name %></h3>
    <p><%= link_to 'Back to Locations', admin_locations_path, class: 'btn btn-outline-secondary btn-sm' %></p>

    <div class="card mb-3">
      <div class="card-body">
        <p><strong>Precision:</strong> <%= @location.precision %></p>
        <p><strong>Latitude:</strong> <%= @location.lat %></p>
        <p><strong>Longitude:</strong> <%= @location.lng %></p>
        <% if @location.neighborhood.present? %>
          <p><strong>Neighborhood:</strong> <%= @location.neighborhood.name %></p>
        <% end %>
      </div>
    </div>

    <% if @location.camp.blank? %>
      <h4>Events at this Location</h4>
      <%= render 'admin/events_table',
                 events:        @current_events,
                 empty_message: 'No events are currently associated with this location.' %>

      <h4 class="mt-4">Past Events</h4>
      <%= render 'admin/events_table',
                 events:        @past_events,
                 empty_message: 'No past events for this location.',
                 show_year:     true %>
    <% end %>

    <% if @location.camp.present? %>
      <h4>Events at the camp at this location</h4>
      <%= render 'admin/events_table',
                 events:        @current_camp_events,
                 empty_message: 'No events are currently associated with the camp at this location.' %>

      <h4 class="mt-4">Past Events at the camp at this location</h4>
      <%= render 'admin/events_table',
                 events:        @past_camp_events,
                 empty_message: 'No past events for the camp at this location.',
                 show_year:     true %>
    <% end %>
  </div>
</div>
